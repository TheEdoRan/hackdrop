{
	"name": "@hackdrop/extension",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"package": "pnpm build && web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --overwrite-dest",
		"lint:webext": "web-ext lint --source-dir=dist",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"preact": "^10.25.1"
	},
	"devDependencies": {
		"@preact/preset-vite": "^2.10.5",
		"@preact/signals": "^2.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/chrome": "^0.0.287",
		"@types/firefox-webext-browser": "^120.0.4",
		"@types/node": "catalog:",
		"tailwindcss": "^4.2.4",
		"typescript": "catalog:",
		"vite": "^8.0.10",
		"web-ext": "^8.3.0"
	}
}
